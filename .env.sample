NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=

# Secret for signing email notification preference/unsubscribe tokens (HMAC).
# Required: the notification token module throws if unset.
NOTIFICATION_HMAC_SECRET=

# Bearer secret for the platform-message admin endpoint.
# Required: the route returns 401 if unset.
PLATFORM_MESSAGE_SECRET=

# Address of the Flow State bot that adds voters for GoodDollar ID eligibility.
# Surfaced in the Voter Groups UI so admins can grant it Voter Manager role.
# Optional: when unset the bot-address line is omitted from the GoodDollar notice.
NEXT_PUBLIC_FLOW_STATE_BOT_ADDRESS=
